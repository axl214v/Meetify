# ==========================================
# Meetify Docker Environment Configuration
# ==========================================

# ==========================================
# Application
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# Database (MySQL)
# ==========================================
DB_HOST=db
DB_USER=root #change in prod
DB_PASSWORD=super_secure_password_change_me
DB_NAME=meetify
DB_PORT=3306

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=super_secure_jwt_change_me
JWT_EXPIRES_IN=24h

# ==========================================
# URLs
# ==========================================
SERVER_URL=http://localhost:3000
CLIENT_URL=http://localhost

# ==========================================
# STUN/TURN Server (bundled coturn)
# ==========================================
#
# COTURN_PUBLIC_IP — the IP address that coturn advertises to WebRTC clients.
#   Local dev  : 127.0.0.1 (default, works out of the box)
#   Production : set to your server's public IP or, preferably, the IP of a
#                dedicated coturn VPS (recommended — TURN traffic bypasses
#                Cloudflare, so running coturn on a separate cheap VPS keeps
#                your main server IP hidden from end users).
#
# STUN_SERVER_URL / TURN_SERVER_URL — must match COTURN_PUBLIC_IP.
#   In production replace 127.0.0.1 with the same IP you set above.
#
COTURN_PUBLIC_IP=62.60.186.59

USE_OWN_STUN_SERVER=true
STUN_SERVER_URL=stun:62.60.186.59:3478
TURN_SERVER_URL=turn:62.60.186.59:3478
TURN_USERNAME=meetify
# Generate a strong secret: openssl rand -hex 32
TURN_PASSWORD=change_me_turn_secret

# ==========================================
# SFU server (mediasoup on a separate VPS)
# ==========================================
# URL that browsers will use to connect directly to the SFU server.
# Example: https://sfu.yourdomain.com  or  wss://sfu.yourdomain.com
SFU_SERVER_URL=https://sfu.yourdomain.com

# Shared secret between main backend and SFU server.
# Generate: openssl rand -hex 32
SFU_SHARED_SECRET=change_me_sfu_secret

# ==========================================
# Conference Settings
# ==========================================
MAX_CONFERENCE_PARTICIPANTS=50
MAX_CONFERENCE_DURATION=86400
RECORDING_ENABLED=false
SCREEN_SHARING_ENABLED=true

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info

# ==========================================
# Third-Party Services (Optional)
# ==========================================
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

XIRSYS_ENABLED=false
XIRSYS_IDENT=
XIRSYS_SECRET=
XIRSYS_CHANNEL=meetify