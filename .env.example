# ==========================================
# Meetify Docker Environment Configuration
# ==========================================

# ==========================================
# Application
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# Database (MySQL)
# ==========================================
DB_HOST=db
DB_USER=root #change in prod
DB_PASSWORD=super_secure_password_change_me
DB_NAME=meetify
DB_PORT=3306

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=super_secure_jwt_change_me
JWT_EXPIRES_IN=24h

# ==========================================
# URLs
# ==========================================
SERVER_URL=http://localhost:3000
CLIENT_URL=http://localhost

# ==========================================
# STUN/TURN Server (bundled coturn)
# ==========================================
# Set COTURN_PUBLIC_IP to your server's public IP for production.
# For local dev, 127.0.0.1 works out of the box.
COTURN_PUBLIC_IP=127.0.0.1

USE_OWN_STUN_SERVER=true
STUN_SERVER_URL=stun:127.0.0.1:3478
TURN_SERVER_URL=turn:127.0.0.1:3478
TURN_USERNAME=meetify
TURN_PASSWORD=change_me_turn_secret

# ==========================================
# mediasoup SFU (Group calls)
# ==========================================
# Set MEDIASOUP_ANNOUNCED_IP to your server's public IP or LAN IP so clients
# can reach the RTC ports. Use 127.0.0.1 for local development only.
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40059

# ==========================================
# Conference Settings
# ==========================================
MAX_CONFERENCE_PARTICIPANTS=50
MAX_CONFERENCE_DURATION=86400
RECORDING_ENABLED=false
SCREEN_SHARING_ENABLED=true

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info

# ==========================================
# Third-Party Services (Optional)
# ==========================================
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

XIRSYS_ENABLED=false
XIRSYS_IDENT=
XIRSYS_SECRET=
XIRSYS_CHANNEL=meetify