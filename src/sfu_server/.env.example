PORT=3001
HOST=0.0.0.0

# Must match SFU_SHARED_SECRET on the main backend
SFU_SHARED_SECRET=change_me_sfu_secret

# Public IP of this SFU server — clients receive this in ICE candidates
MEDIASOUP_ANNOUNCED_IP=YOUR_SFU_SERVER_IP

MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40059
MEDIASOUP_NUM_WORKERS=2

# Comma-separated list of allowed client origins (your frontend domain)
CLIENT_ORIGINS=https://yourdomain.com
