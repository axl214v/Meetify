# ==========================================
# Meetify Environment Configuration
# ==========================================

# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
SERVER_URL=http://0.0.0.0:3000

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=super_secure_password_change_me
DB_NAME=meetify
DB_PORT=3306

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=ca3a135367a12484eb1042af339ed2486d8b3748788eb2162573d4868066e5515d343d1b4ee07ef505a2b46c53d1af81c23d1b5013e2c1748fb66260e311368d
JWT_EXPIRES_IN=24h

# ==========================================
# Client Configuration
# ==========================================
CLIENT_URL=http://localhost:3000

# ==========================================
# STUN/TURN Server Configuration
# ==========================================

# Use your own STUN/TURN server (true/false)
USE_OWN_STUN_SERVER=false

# Your STUN Server
STUN_SERVER_URL=stun:your-server.com:3478

# Your TURN Server
TURN_SERVER_URL=turn:your-server.com:3478
TURNS_SERVER_URL=turns:your-server.com:5349
TURN_USERNAME=meetify_user
TURN_PASSWORD=your_turn_secret_password

# ==========================================
# Third-Party TURN Services (Optional)
# ==========================================

# Twilio STUN/TURN (https://www.twilio.com/stun-turn)
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Xirsys (https://xirsys.com/)
XIRSYS_ENABLED=false
XIRSYS_IDENT=your_xirsys_ident
XIRSYS_SECRET=your_xirsys_secret
XIRSYS_CHANNEL=meetify

# ==========================================
# Conference Limits
# ==========================================
MAX_CONFERENCE_PARTICIPANTS=50
MAX_CONFERENCE_DURATION=86400
RECORDING_ENABLED=false
SCREEN_SHARING_ENABLED=true

# ==========================================
# File Upload Configuration
# ==========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ==========================================
# Email Configuration (Optional)
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_email_password
# EMAIL_FROM=noreply@meetify.com

# ==========================================
# Production Security (Only for production)
# ==========================================
# HTTPS_ENABLED=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
# FORCE_HTTPS=true



SENTRY_DSN=your_sentry_dsn
ANALYTICS_ENABLED=false