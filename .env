# ==========================================
# Meetify Docker Environment Configuration
# ==========================================

# ==========================================
# Application
# ==========================================
NODE_ENV=production
PORT=3000

# ==========================================
# Database (MySQL)
# ==========================================
DB_HOST=db
DB_USER=meetify_user
DB_PASSWORD=super_secure_password_change_me
DB_NAME=meetify
DB_PORT=3306

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_for_security
JWT_EXPIRES_IN=24h

# ==========================================
# URLs
# ==========================================
SERVER_URL=http://localhost:3000
CLIENT_URL=http://localhost

# ==========================================
# STUN/TURN Server
# ==========================================
USE_OWN_STUN_SERVER=false
STUN_SERVER_URL=stun:stun.l.google.com:19302
TURN_SERVER_URL=
TURN_USERNAME=
TURN_PASSWORD=

# ==========================================
# Conference Settings
# ==========================================
MAX_CONFERENCE_PARTICIPANTS=50
MAX_CONFERENCE_DURATION=86400
RECORDING_ENABLED=false
SCREEN_SHARING_ENABLED=true

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info

# ==========================================
# Third-Party Services (Optional)
# ==========================================
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

XIRSYS_ENABLED=false
XIRSYS_IDENT=
XIRSYS_SECRET=
XIRSYS_CHANNEL=meetify